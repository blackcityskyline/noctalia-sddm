#!/bin/bash
THEME="${1:-noctalia-sddm}"
THEME_DIR="$HOME/.local/share/sddm/themes/$THEME"

WALLPAPER=$(python3 -c "
import json
with open('$HOME/.cache/noctalia/wallpapers.json') as f:
    d = json.load(f)
screens = d.get('wallpapers', {})
first = next(iter(screens.values()), {})
print(first.get('dark') or first.get('light') or '')
")

AVATAR=$(python3 -c "
import json
with open('$HOME/.config/noctalia/settings.json') as f:
    d = json.load(f)
print(d.get('general', {}).get('avatarImage', ''))
")

if [ -n "$AVATAR" ] && [ -f "$AVATAR" ]; then
  if grep -q "^avatarPath=" ~/.cache/noctalia/sddm-theme.conf; then
    sed -i "s|^avatarPath=.*|avatarPath=$AVATAR|" ~/.cache/noctalia/sddm-theme.conf
  else
    echo "avatarPath=$AVATAR" >>~/.cache/noctalia/sddm-theme.conf
  fi
fi

tee "$THEME_DIR/theme.conf" <~/.cache/noctalia/sddm-theme.conf >/dev/null
[ -f "$WALLPAPER" ] && cp "$WALLPAPER" "$THEME_DIR/Assets/background.png"
